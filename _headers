# HEARTH™ — Netlify Headers

/resources/*.xlsx
  Content-Type: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
  Content-Disposition: attachment

/resources/*.docx
  Content-Type: application/vnd.openxmlformats-officedocument.wordprocessingml.document
  Content-Disposition: attachment

/resources/*.pdf
  Content-Type: application/pdf
  Content-Disposition: attachment

# Netlify functions — must be unrestricted so the browser can POST to them
/.netlify/functions/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Headers: Content-Type
  Access-Control-Allow-Methods: POST, OPTIONS

# Security headers for HTML pages only (not functions)
/*.html
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: form-action 'self' https://docs.google.com; connect-src 'self' https://docs.google.com https://api.emailjs.com https://cdn.jsdelivr.net
